{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadTokyoDbSecret",
      "Effect": "Allow",
      "Action": [
        "secretsmanager:GetSecretValue",
        "secretsmanager:DescribeSecret"
      ],
      "Resource": "arn:aws:secretsmanager:ap-northeast-1:233781468925:secret:lab1a/rds/mysql*"
    },
    {
      "Sid": "ReadTokyoDbParams",
      "Effect": "Allow",
      "Action": [
        "ssm:GetParameter",
        "ssm:GetParameters",
        "ssm:GetParametersByPath"
      ],
      "Resource": "arn:aws:ssm:ap-northeast-1:233781468925:parameter/lab/db/*"
    }
  ]
}
